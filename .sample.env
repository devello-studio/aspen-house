# Copy to ".env" or ".env.local" and fill in values (never commit real secrets).
#
# Turnstile: add VITE_TURNSTILE_SITE_KEY (site key from Cloudflare Turnstile dashboard),
# then restart the Vite dev server so the variable is picked up.
#
# Local form submissions: run API + Vite — npm run dev:all
#   or: npm run dev:api in one terminal and npm run dev in another.
#
# Docker Compose dev profile (`--profile dev`): Vite proxies to the api container;
# compose sets API_PROXY_TARGET=http://api:3000 — no need to set locally unless you override.

# --- Vite (browser) — only vars prefixed with VITE_ are exposed to the client ---
VITE_TURNSTILE_SITE_KEY=

# --- api/contact.js (server) — required when the handler runs (see below) ---
TURNSTILE_SECRET_KEY=
RESEND_API_KEY=
RESEND_FROM=
FORM_NOTIFICATION_EMAIL=
